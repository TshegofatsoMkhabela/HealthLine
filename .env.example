# Env vars Render's dashboard sets per-service in production. Not needed for local
# `docker compose up` — that wires backend to compose's own throwaway postgres container
# automatically (see docker-compose.yml). Documented here so they're not only discoverable by
# reading source (see DatabaseUrlEnvironmentPostProcessor.java, application.properties).

# backend — Supabase Postgres connection (postgres:// or postgresql://, normalized at boot)
DATABASE_URL=
DATABASE_USER=
DATABASE_PASSWORD=

# backend — ai-service's own Render URL. Inside docker-compose this is overridden to
# http://ai-service:8000 automatically; only needed here for a non-compose real deploy.
AI_SERVICE_BASE_URL=

# both services — Render sets this per-instance; defaults to 8080 (backend) / 8000 (ai-service)
# if unset, so only needed if you're overriding the default locally.
PORT=

# frontend — optional; the app runs fine without them and falls back to mocked
# data/UI (plain coordinates instead of a Mapbox map, etc.)
VITE_MAPBOX_TOKEN=
VITE_WHAT3WORDS_API_KEY=
